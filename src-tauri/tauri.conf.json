{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MagicalFlyingAlpaca",
  "version": "1.0.0",
  "identifier": "com.magicalflyingalpaca.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Magical Flying Alpaca",
        "width": 400,
        "height": 560,
        "resizable": true,
        "center": true,
        "minWidth": 400,
        "minHeight": 540
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "wix": {
        "language": "ja-JP"
      }
    },
    "resources": []
  },
  "plugins": {}
}
